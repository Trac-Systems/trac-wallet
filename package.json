{
  "name": "trac-wallet",
  "version": "1.0.2",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    },
    "./package.json": "./package.json"
  },
  "type": "module",
  "pear": {
    "name": "trac-wallet",
    "type": "terminal"
  },
  "scripts": {
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "clean:test": "node -e \"require('node:fs').rmSync('.test-build', { recursive: true, force: true })\"",
    "build": "npm run clean:dist && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test:prepare": "npm run clean:test && tsc -p tsconfig.test.json",
    "test:node": "npm run test:prepare && brittle-node -c -t 180000 .test-build/test/all.test.js",
    "test:bare": "npm run test:prepare && brittle-bare -c -t 180000 .test-build/test/all.test.js",
    "test": "npm run test:node",
    "prepack": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "b4a": "1.6.7",
    "bare-fs": "^4.0.2",
    "bare-path": "^3.0.0",
    "bare-readline": "1.0.7",
    "bare-tty": "^5.0.2",
    "fs": "npm:bare-node-fs",
    "path": "npm:bare-node-path",
    "readline": "npm:bare-node-readline",
    "trac-crypto-api": "0.1.4",
    "tty": "npm:bare-node-tty"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "brittle": "^3.18.0",
    "sodium-universal": "^5.0.1",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Trac-Systems/trac-wallet"
  }
}
